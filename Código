# 3. MODELO SIMPLES CORHAY — APENDICE A (ilustrativo)
# ─────────────────────────────────────────────────────────────────
def corhay_model(rho_pi, delta_b,
                 lam=LAM, phi=PHI, sigma=SIG_C,
                 b_star=B_STAR, s_star=S_STAR):
    k1 = b_star/(b_star+s_star)
    k2 = 1/(b_star+s_star)
    A1 = 1/(k1*phi + k2*delta_b - 1 + 1e-10)
    H1 = 1/(rho_pi - phi + 1e-10)
    TP_mon = -(lam+H1*sigma)*rho_pi*H1*sigma

    def TP_f(O):
        z1=k1*A1; d=1+rho_pi*O+1e-10
        return rho_pi*(lam-z1*sigma/d)*(z1*sigma/d)

    def dEpi(O):
        return TP_f(O)/(1+rho_pi*O+1e-10)

    return dict(A1=A1, H1=H1, TP_mon=TP_mon, TP_f=TP_f, dEpi=dEpi,
                rho_pi=rho_pi, delta_b=delta_b, kappa1=k1, kappa2=k2,
                lam=lam, phi=phi, sigma=sigma, b_star=b_star, s_star=s_star)


def compute_irfs(m, T=40, omega_bar=1.0, shock=-0.50):
    rO=m['phi']
    Omega=np.array([omega_bar+shock*(rO**t) for t in range(T)])
    TP=np.array([m['TP_f'](o) for o in Omega])
    dEpi=np.array([m['dEpi'](o)*shock*(rO**t) for t,o in enumerate(Omega)])
    return dict(periods=np.arange(T), Omega=Omega-omega_bar,
                TP=(TP-TP[0])*10000, Epi=np.cumsum(dEpi)*10000)


