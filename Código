def run_robustness(df, res):
    """
    Testes simples conforme orientacao do professor:
    - Remove 12 meses do inicio ou fim da amostra
    - Remove variaveis uma a uma
    - O coeficiente de P(Fiscal) deve ser estavel
    """
    df_r=df.copy(); df_r['prob_fiscal']=res['xi_smooth'][:,1]
    DUM=[d for d in ['dummy_covid','dummy_teto_gastos'] if d in df_r.columns]
    BASE_X=['prob_fiscal','omega_t','selic','divida_bruta_pib']+DUM

    DEP=[('cds_5y','CDS 5Y (bps)'),('embi_plus','EMBI+ (bps)'),
         ('term_premium','Term Premium (%)'),('juros_reais','Juros Reais (%)')]

    # (label, corte_inicio, corte_fim, xcols, dep_override)
    TESTES=[
        ('Base',             0,  0,  BASE_X,                                                    None),
        ('T1 - Rem. 12m ini',12, 0,  BASE_X,                                                    None),
        ('T2 - Rem. 12m fim', 0,12,  BASE_X,                                                    None),
        ('T3 - Sem Omega_t',  0, 0,  ['prob_fiscal','selic','divida_bruta_pib']+DUM,             None),  # sem omega_t
        ('T4 - Sem macro',    0, 0,  ['prob_fiscal','omega_t']+DUM,                              None),
        ('T5 - Sem dummies',  0, 0,  ['prob_fiscal','omega_t','selic','divida_bruta_pib'],        None),
        ('T6 - So D.Teto',    0, 0,  ['prob_fiscal','omega_t','selic',
                                       'divida_bruta_pib','dummy_teto_gastos'],                   None),
        ('T7 - log(EMBI)',    0, 0,  BASE_X,                                                    'log_embi'),
    ]

    print(f"\n{'='*70}")
    print("TESTES DE ROBUSTEZ")
    print("Criterio: beta P(Fiscal) deve ser estavel em magnitude e significancia")
    print(f"{'='*70}")
    print(f"Amostra base: {df_r['date'].min().strftime('%Y-%m')} -> "
          f"{df_r['date'].max().strftime('%Y-%m')}  N={len(df_r)}")

    results={}
    for dep,dep_lbl in DEP:
        print(f"\n  {'─'*65}")
        print(f"  Dep.: {dep_lbl}")
        print(f"  {'─'*65}")
        print(f"  {'Teste':<28} {'N':>5}  {'beta P(Fis)':>11}  {'SE':>8}  "
              f"{'t':>6}  {'p':>7}  {'sig':>4}  {'R2':>6}")
        print(f"  {'─'*65}")
        results[dep]={}

        for lbl,n_ini,n_fim,xcols,dep_ov in TESTES:
            n_fim_idx = len(df_r)-n_fim if n_fim>0 else len(df_r)
            df_t=df_r.iloc[n_ini:n_fim_idx].reset_index(drop=True)

            actual_dep=dep_ov if dep_ov else dep
            # T7 so para embi_plus
            if dep_ov is not None and dep!='embi_plus':
                results[dep][lbl]=None; continue

            r=_ols_hac(df_t,actual_dep,xcols)
            results[dep][lbl]=r
            if r is None:
                print(f"  {lbl:<28} {'N<24':>5}"); continue

            sig='***' if r['p1']<.01 else '**' if r['p1']<.05 else '*' if r['p1']<.10 else ''
            print(f"  {lbl:<28} {r['N']:>5}  {r['b1']:>11.4f}  "
                  f"{r['se1']:>8.4f}  {r['t1']:>6.2f}  "
                  f"{r['p1']:>7.4f}  {sig:>4}  {r['r2']:>6.3f}")

    print(f"\n  *** p<0.01  ** p<0.05  * p<0.10")
    return results


