# 4. OLS-HAC — resultado principal
# ─────────────────────────────────────────────────────────────────
def newey_west(X, e, lags=12):
    T,k=X.shape; S=X.T@np.diag(e**2)@X/T
    for j in range(1,lags+1):
        w=1-j/(lags+1); G=X[j:].T@np.diag(e[j:]*e[:-j])@X[:-j]/T
        S+=w*(G+G.T)
    return np.sqrt(np.diag(np.linalg.pinv(X.T@X/T)@S@np.linalg.pinv(X.T@X/T)/T))


def _ols_hac(df_in, dep, xcols, lags=12):
    avail=[c for c in xcols if c in df_in.columns]
    if dep not in df_in.columns: return None
    sub=df_in[[dep]+avail].dropna()
    if len(sub)<24: return None
    y=sub[dep].values
    X=np.column_stack([np.ones(len(sub))]+[sub[c].values for c in avail])
    b=np.linalg.lstsq(X,y,rcond=None)[0]; e=y-X@b
    T_,k=len(y),X.shape[1]
    se=newey_west(X,e,lags); ts=b/se; pv=2*(1-t_dist.cdf(np.abs(ts),df=T_-k))
    r2=1-(e@e)/((y-y.mean())@(y-y.mean()))
    r2a=1-(1-r2)*(T_-1)/(T_-k)
    return dict(b=b,se=se,t=ts,p=pv,r2=r2,r2a=r2a,N=T_,
                b1=b[1],se1=se[1],t1=ts[1],p1=pv[1],avail=avail)


def run_ols(df, res):
    df_r=df.copy(); df_r['prob_fiscal']=res['xi_smooth'][:,1]
    # dummy_rec2001 nao existe na base v7 — removida
    DUM=[d for d in ['dummy_covid','dummy_teto_gastos'] if d in df_r.columns]

    # Para o breakeven, P(Fiscal) ~ 0.999 em quase toda a subamostra (fev/2014 em diante),
    # gerando colinearidade perfeita com a constante. Solucao: usar delta_P_fiscal
    # (primeira diferenca) como proxy de variacao de regime no breakeven.
    df_r['delta_p_fiscal'] = df_r['prob_fiscal'].diff().fillna(0)

    SPECS=[
        ('M1 - Base',       ['prob_fiscal','omega_t'],                           False),
        ('M2 - +Macro',     ['prob_fiscal','omega_t','selic','divida_bruta_pib'],False),
        ('M3 - +Ext.',      ['prob_fiscal','omega_t','selic','divida_bruta_pib',
                              'log_vix','fed_rate'],                              False),
        ('M4 - Base+Dum',   ['prob_fiscal','omega_t'],                           True),
        ('M5 - +Macro+Dum', ['prob_fiscal','omega_t','selic','divida_bruta_pib'],True),
    ]
    # Breakeven: P(Fiscal) excluido das especificacoes porque ~0.999 em toda a subamostra
    # (fev/2014 em diante = todo fiscal). Incluir P(Fiscal) em nivel gera colinearidade
    # perfeita com a constante -> coeficientes na casa de milhoes. 
    # Solucao: usar apenas Selic, Omega_t e controles externos para o breakeven.
    SPECS_BRK=[
        ('M1 - Base',       ['omega_t'],                                             False),
        ('M2 - +Macro',     ['omega_t','selic','divida_bruta_pib'],                  False),
        ('M3 - +Ext.',      ['omega_t','selic','divida_bruta_pib',
                              'log_vix','fed_rate'],                              False),
        ('M4 - Base+Dum',   ['omega_t'],                                             True),
        ('M5 - +Macro+Dum', ['omega_t','selic','divida_bruta_pib'],                  True),
    ]
    DEP_VARS=[
        ('cds_5y','CDS Brasil 5Y (bps)'),
        ('embi_plus','EMBI+ Brasil (bps)'),
        ('term_premium','Term Premium 10Y-1Y (%)'),
        ('breakeven_10y','Breakeven Inflacao 10Y (%)'),
        ('juros_reais','Juros Reais Ex-Post (%)'),
    ]
    NOMES={'prob_fiscal':'P(Fiscal)','delta_p_fiscal':'dP(Fiscal)',
           'omega_t':'Omega_t','selic':'Selic','divida_bruta_pib':'Div/PIB',
           'log_vix':'log(VIX)','fed_rate':'FED',
           'dummy_covid':'D.COVID','dummy_teto_gastos':'D.Teto'}

    all_res={}
    for dep,lbl in DEP_VARS:
        if dep not in df_r.columns: continue
        if dep == 'breakeven_10y':
            print(f"\n{'='*65}")
            print(f"{lbl}  [HAC 12 lags]")
            print(f"{'='*65}")
        else:
            print(f"\n{'='*65}\n{lbl}  [HAC 12 lags]\n{'='*65}")
        all_res[dep]={}
        # Breakeven usa especificacoes alternativas com delta_P_fiscal
        spec_list = SPECS_BRK if dep == 'breakeven_10y' else SPECS
        for spec,xcols,has_d in spec_list:
            cols=xcols+(DUM if has_d else [])
            r=_ols_hac(df_r,dep,cols)
            if r is None: print(f"  {spec}: N insuficiente"); continue
            nm=['Const.']+[NOMES.get(v,v) for v in r['avail']]
            sep='\n  --- COM DUMMIES ---' if has_d and not all_res[dep] else ''
            print(f"{sep}\n  {spec}  N={r['N']}  R2={r['r2']:.3f}  R2adj={r['r2a']:.3f}")
            print(f"  {'Var':<20} {'beta':>9} {'SE':>8} {'t':>7} {'p':>7}")
            for nm_,b_,s_,t_,p_ in zip(nm,r['b'],r['se'],r['t'],r['p']):
                sig='***' if p_<.01 else '**' if p_<.05 else '*' if p_<.10 else ''
                print(f"  {nm_:<20} {b_:>9.4f} {s_:>8.4f} {t_:>7.3f} {p_:>7.4f} {sig}")
            all_res[dep][spec]=r

    print(f"\n  Dummies: D.2001(NBER), D.COVID(NBER+CODACE), D.Teto(EC95/2016)")
    return all_res


