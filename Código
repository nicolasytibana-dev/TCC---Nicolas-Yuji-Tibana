# 2. MARKOV-SWITCHING
# ─────────────────────────────────────────────────────────────────
def _filter(p, y_t, y_f, Xt, Xf):
    T = len(y_t)
    a   = p[0:2]
    rp  = np.array([1+np.exp(np.clip(p[2],-5,5)),
                    1-np.exp(np.clip(p[3],-5,5))])
    sig = np.exp(np.clip(p[4:6],-3,3)) + 1e-8
    g   = p[6:8]
    db  = np.array([ np.exp(np.clip(p[8],-6,3)),
                    -np.exp(np.clip(p[9],-6,3))])
    om  = np.exp(np.clip(p[10:12],-3,3)) + 1e-8
    pMM = 1/(1+np.exp(-np.clip(p[12],-8,8)))
    pFF = 1/(1+np.exp(-np.clip(p[13],-8,8)))
    P   = np.array([[pMM,1-pFF],[1-pMM,pFF]])

    A  = np.vstack([(P.T-np.eye(2)), np.ones((1,2))])
    bv = np.zeros(3); bv[-1] = 1
    pi = np.linalg.lstsq(A, bv, rcond=None)[0]
    pi = np.clip(pi,1e-6,1-1e-6); pi /= pi.sum()

    mu_t = np.stack([a[s]+rp[s]*Xt[:,0] for s in range(2)], 1)
    mu_f = np.stack([g[s]+db[s]*Xf[:,0] for s in range(2)], 1)
    eta  = (norm.pdf(y_t[:,None]-mu_t, 0, sig) *
            norm.pdf(y_f[:,None]-mu_f, 0, om))

    xi_f = np.zeros((T,2)); xi_p = pi.copy(); ll = 0.0
    for t in range(T):
        ft = xi_p @ eta[t]
        if ft < 1e-300: return 1e10, xi_f
        ll += np.log(ft)
        xi_f[t] = xi_p*eta[t]/ft
        if t < T-1: xi_p = P.T @ xi_f[t]

    prior = (4*np.log(pMM+1e-8)+np.log(1-pMM+1e-8) +
             4*np.log(pFF+1e-8)+np.log(1-pFF+1e-8))
    return -ll-prior, xi_f


def _smooth(xi_f, P):
    T, ns = xi_f.shape
    xs = np.zeros_like(xi_f); xs[-1] = xi_f[-1]
    for t in range(T-2,-1,-1):
        pred = P @ xi_f[t]
        for s in range(ns):
            xs[t,s] = xi_f[t,s]*sum(P[s,j]*xs[t+1,j]/(pred[j]+1e-15)
                                     for j in range(ns))
        tot = xs[t].sum()
        xs[t] = xs[t]/tot if tot > 1e-15 else xi_f[t]
    return xs


def estimate_ms(df, n_seeds=N_SEEDS):
    def znorm(x): return (x-x.mean(0))/(x.std(0)+1e-8)

    y_t = df['selic'].values
    y_f = df['fiscal_pib'].values
    Xt  = df[['ipca_mes']].values
    Xf  = df[['log_div_bruta_lag']].values

    yn=znorm(y_t); yfn=znorm(y_f)
    Xtn=znorm(Xt); Xfn=znorm(Xf)
    obj = lambda p: _filter(p, yn, yfn, Xtn, Xfn)[0]

    seeds = [
        [0.,0.,np.log(.80),np.log(.15),0.3,0.5,0.2,-0.1,-2.7,-3.5,0.,0.3,3.0,3.5],
        [0.,0.,np.log(.90),np.log(.15),0.5,0.8,0.3,-0.2,-2.5,-3.8,-0.2,0.5,3.5,3.0],
        [0.,0.,np.log(.70),np.log(.20),0.4,0.6,0.2,-0.1,-3.0,-4.0,0.1,0.4,2.8,3.2],
        [0.,0.,np.log(.85),np.log(.12),0.6,0.7,0.4,-0.3,-2.3,-3.2,-0.3,0.6,3.8,2.8],
        [0.,0.,np.log(.75),np.log(.18),0.4,0.5,0.1,-0.1,-2.8,-3.6,0.0,0.3,2.5,3.5],
        [0.,0.,np.log(.95),np.log(.10),0.5,0.7,0.2,-0.2,-2.7,-3.5,0.0,0.5,3.2,2.5],
        [0.,0.,np.log(.85),np.log(.15),0.5,0.6,0.3,-0.2,-3.2,-3.3,0.1,0.4,2.8,3.0],
        [0.,0.,np.log(.80),np.log(.20),0.4,0.5,0.2,-0.2,-3.1,-3.4,0.0,0.4,2.6,3.0],
    ][:n_seeds]

    print(f"\n{'='*65}")
    print(f"MARKOV-SWITCHING  |  N={len(df)}  |  {n_seeds} sementes  |  14 params")
    print(f"Taylor: it=a(s)+rho_pi(s)*pi_t  |  Fiscal: st=g(s)+delta_b(s)*log(b_t-1)")
    print(f"{'='*65}")

    t0=time.time(); best_nll=1e10; best_p=None
    for i,s in enumerate(seeds):
        r = minimize(obj, np.array(s), method='Nelder-Mead',
                     options={'maxiter':15000,'xatol':1e-8,'fatol':1e-8,'disp':False})
        if np.isfinite(r.fun) and r.fun < best_nll:
            best_nll=r.fun; best_p=r.x.copy()
        rp1=1+np.exp(np.clip(r.x[2],-5,5)); rp2=1-np.exp(np.clip(r.x[3],-5,5))
        pM=1/(1+np.exp(-r.x[12])); pF=1/(1+np.exp(-r.x[13]))
        print(f"  S{i+1:2d}/{n_seeds}  NLL={r.fun:9.2f}  "
              f"rho_pi=[{rp1:.3f},{rp2:.3f}]  pMM={pM:.4f}  pFF={pF:.4f}  "
              f"{time.time()-t0:.0f}s")

    if best_p is None: sys.exit("[ERRO] Nenhuma semente convergiu")

    p   = best_p
    rp1 = 1+np.exp(np.clip(p[2],-5,5))
    rp2 = 1-np.exp(np.clip(p[3],-5,5))
    sig = np.exp(np.clip(p[4:6],-3,3))
    db1 =  np.exp(np.clip(p[8],-6,3))
    db2 = -np.exp(np.clip(p[9],-6,3))
    om  = np.exp(np.clip(p[10:12],-3,3))
    pMM = 1/(1+np.exp(-p[12])); pFF=1/(1+np.exp(-p[13]))
    P   = np.array([[pMM,1-pFF],[1-pMM,pFF]])
    _, xi_f  = _filter(p, yn, yfn, Xtn, Xfn)
    xi_s     = _smooth(xi_f, P)
    regime   = np.argmax(xi_s, axis=1)
    n_trocas = int((np.diff(regime)!=0).sum())
    T_, k    = len(df), 14

    return dict(params=p, rp1=rp1, rp2=rp2, sig=sig,
                db1=db1, db2=db2, om=om, pMM=pMM, pFF=pFF, P=P,
                xi_filt=xi_f, xi_smooth=xi_s, regime=regime,
                nll=best_nll, aic=2*best_nll+2*k,
                bic=2*best_nll+k*np.log(T_), n_trocas=n_trocas)


