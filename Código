def export_csv(df, res):
    out=df.copy()
    out['prob_monetario']=res['xi_smooth'][:,0]
    out['prob_fiscal']   =res['xi_smooth'][:,1]
    out['regime']        =np.where(res['regime']==0,'Monetario','Fiscal')
    path=os.path.join(OUTPUT_DIR,'resultados_ms_v7.csv')
    out.to_csv(path,index=False); print(f"[CSV] {path}")


