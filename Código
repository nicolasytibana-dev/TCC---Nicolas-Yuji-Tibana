def _shade(ax, dates, xi_s):
    f=xi_s[:,1]>0.5; in_ep=False
    for t in range(len(dates)):
        if f[t] and not in_ep: st=dates[t]; in_ep=True
        elif not f[t] and in_ep:
            ax.axvspan(pd.Timestamp(st),pd.Timestamp(dates[t-1]),
                       color=C_LARN,alpha=0.18,zorder=0); in_ep=False
    if in_ep: ax.axvspan(pd.Timestamp(st),pd.Timestamp(dates[-1]),
                         color=C_LARN,alpha=0.18,zorder=0)

def _events(ax):
    ax.axvspan(pd.Timestamp('2020-02-01'),pd.Timestamp('2020-12-01'),
               color='#CCCCCC',alpha=0.65,zorder=1)
    ax.axvline(pd.Timestamp('2016-12-01'),color=C_AZUL,lw=0.9,ls=':',alpha=0.7)

def _fmt(ax, title, ylabel=None):
    ax.set_title(title,fontsize=8.5,fontweight='bold',pad=3)
    ax.tick_params(labelsize=7); ax.set_facecolor('white')
    ax.xaxis.set_major_formatter(mdates.DateFormatter('%Y'))
    ax.xaxis.set_major_locator(mdates.YearLocator(4))
    plt.setp(ax.xaxis.get_majorticklabels(),rotation=45,ha='right')
    for sp in ax.spines.values(): sp.set_edgecolor('#CCCCCC')
    ax.grid(axis='y',alpha=0.3,lw=0.5)
    if ylabel: ax.set_ylabel(ylabel,fontsize=7.5)


